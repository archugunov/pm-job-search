userdata/*
!userdata/examples/
!userdata/.gitkeep
.env
.DS_Store
.claude/
.superpowers/
SPEC.md
# Workspace CLAUDE.md is regenerated by /setup on every in-repo run — a test
# artifact, never plugin source (the template lives at plugin/templates/).
/CLAUDE.md
# Private author material — must never be committed.
/eval-layer-briefing.md
# Privacy filter patterns — local-only, never committed.
.privacy-patterns.local
# Internal design docs (specs/plans) are private by default; the demo bundle
# files at docs/{index.html,assets/,demo/} are the public part of docs/.
/docs/superpowers/
# Dashboard build deps and artefacts
plugin/dashboard/node_modules/
.venv/
**/.venv/
**/*.tsbuildinfo
plugin/dashboard/vite.config.d.ts
plugin/dashboard/vite.config.js
# Snapshot output for the demo bundle — regenerated by `make demo`.
plugin/dashboard/public/demo/
